### Track event
POST http://localhost:3000/v1/events/track
Content-Type: application/json
x-rapidapi-key: demo-key

{
  "user_id": "usr_12345",
  "event": "login",
  "ip": "41.13.67.45",
  "metadata": {
    "device_type": "desktop"
  }
}

### Report fraud
POST http://localhost:3000/v1/events/report
Content-Type: application/json
x-rapidapi-key: demo-key

{
  "user_id": "usr_12345",
  "report_type": "chargeback",
  "confirmed": true,
  "details": "User performed 3 chargebacks within 7 days",
  "email": "user@domain.com",
  "ip": "41.13.67.45"
}

### Get user profile
GET http://localhost:3000/v1/users/usr_12345/profile
x-rapidapi-key: demo-key

### Update trust score
PATCH http://localhost:3000/v1/users/usr_12345/trust-score
Content-Type: application/json
x-rapidapi-key: demo-key

{
  "adjustment": "increase",
  "value": 20,
  "reason": "manual_review_cleared",
  "notes": "Support team verified identity via video call"
}

### Get linked accounts
GET http://localhost:3000/v1/users/usr_12345/linked-accounts
x-rapidapi-key: demo-key

### Check velocity
GET http://localhost:3000/v1/velocity/check?entity_type=ip&entity_value=41.13.67.45&windows=1h,24h
x-rapidapi-key: demo-key

### Get anomalies
GET http://localhost:3000/v1/anomalies?severity=all&type=all&hours=24
x-rapidapi-key: demo-key

### Get stats
GET http://localhost:3000/v1/stats?period=30d
x-rapidapi-key: demo-key

### Get configuration
GET http://localhost:3000/v1/config/thresholds
x-rapidapi-key: demo-key

### Update configuration
POST http://localhost:3000/v1/config/thresholds
Content-Type: application/json
x-rapidapi-key: demo-key

{
  "thresholds": {
    "allow": 60,
    "challenge": 35,
    "block": 0
  },
  "action_overrides": {
    "payment": { "allow": 75, "challenge": 50, "block": 0 },
    "signup": { "allow": 55, "challenge": 30, "block": 0 }
  }
}

