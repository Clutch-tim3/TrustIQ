# ─── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Database (required) ───────────────────────────────────────────────────────
# Railway sets this automatically when you attach a PostgreSQL plugin
DATABASE_URL=postgresql://trustiq:password@localhost:5432/trustiq

# ─── Redis (optional) ──────────────────────────────────────────────────────────
# Leave blank to use in-memory fallback for caching, rate limiting, and velocity.
# BullMQ background jobs are disabled when this is absent.
# Railway sets this automatically when you attach a Redis plugin.
REDIS_URL=redis://localhost:6379

# ─── AI (required for /assess AI explanations) ────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── External signal enrichment (all optional) ────────────────────────────────
ABUSEIPDB_API_KEY=
VPNAPI_KEY=

# ─── Velocity thresholds ──────────────────────────────────────────────────────
VELOCITY_THRESHOLD_IP_1H=30
VELOCITY_THRESHOLD_IP_24H=100
VELOCITY_THRESHOLD_DOMAIN_24H=50
VELOCITY_THRESHOLD_DEVICE_1H=10

# ─── Trust score thresholds ───────────────────────────────────────────────────
DEFAULT_ALLOW_THRESHOLD=61
DEFAULT_CHALLENGE_THRESHOLD=40
DEFAULT_BLOCK_THRESHOLD=20

# ─── Cache TTLs ───────────────────────────────────────────────────────────────
IP_CACHE_TTL_HOURS=24
EMAIL_DOMAIN_CACHE_TTL_HOURS=6
DEVICE_CACHE_TTL_DAYS=30

# ─── Feature flags ────────────────────────────────────────────────────────────
ENABLE_AI_EXPLANATIONS=true
ENABLE_BACKGROUND_JOBS=true
ENABLE_ANOMALY_DETECTION=true
